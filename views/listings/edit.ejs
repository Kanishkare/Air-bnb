<% layout("/layouts/boilerplate") %>

<h3>Edit Listing</h3>

<!-- Debug the listing ID -->
<p>DEBUG: <%= listing._id %></p>

<form method="POST" action="/listings/<%= listing._id %>">
  <!-- Important: method-override hidden field -->
  <input type="hidden" name="_method" value="PUT" />

  <div class="mb-3">
    <label>Title</label>
    <input type="text" name="listing[title]" value="<%= listing.title %>" class="form-control" required />
  </div>

  <div class="mb-3">
    <label>Description</label>
    <textarea name="listing[description]" class="form-control" required><%= listing.description %></textarea>
  </div>

  <div class="mb-3">
    <label>Image URL</label>
    <input type="text" name="listing[image]" value="<%= listing.image?.url || listing.image %>" class="form-control" />
    <small>Leave blank to keep the current image.</small>
  </div>

  <div class="mb-3">
    <label>Price</label>
    <input type="number" name="listing[price]" value="<%= listing.price %>" class="form-control" required />
  </div>

  <div class="mb-3">
    <label>Country</label>
    <input type="text" name="listing[country]" value="<%= listing.country %>" class="form-control" required />
  </div>

  <div class="mb-3">
    <label>Location</label>
    <input type="text" name="listing[location]" value="<%= listing.location %>" class="form-control" required />
  </div>

  <button class="btn btn-dark" type="submit">Update Listing</button>
</form>
