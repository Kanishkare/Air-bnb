<% layout("/layouts/boilerplate") %>

<body class="container mt-4">
    </br>
    <h3>Create a New Listing</h3>
    <form method="POST" action="/listings" novalidate class="needs-validation">
      
      <div class="mb-3 col-md-4">
        <label for="title" class="form-label">Enter Title</label>
        <input id="title" name="listing[title]" placeholder="enter title" type="text" class="form-control" required>
      </div>
     
      <div class="mb-3 col-md-8">
        <label for="description" class="form-label">Enter Description</label>
        <input id="description" name="listing[description]" placeholder="enter description" type="text" class="form-control" required>
      </div>

      <div class="mb-3">
        <label for="image" class="form-label">Enter Image URL</label>
        <input id="image" name="listing[image]" placeholder="enter image URL" type="text" class="form-control" required>
      </div>

      <div class="mb-3">
  <label for="country" class="form-label">Enter Country</label>
  <input id="country" name="listing[country]" placeholder="enter country" type="text" class="form-control" required>
</div>

    
      <div class="mb-3">
        <label for="price" class="form-label">Enter Price</label>
        <input id="price" name="listing[price]" placeholder="enter price" type="number" class="form-control" required>
      </div>
      
      <div class="mb-3">
        <label for="location" class="form-label">Enter Location</label>
        <input id="location" name="listing[location]" placeholder="enter location" type="text" class="form-control" required>
      </div>
    
      <button class="btn btn-dark add-btn">Add</button>
      </br></br>
    </form>

    



